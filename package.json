{
  "name": "utlogiclabs-starter-kit",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "cli"
  ],
  "scripts": {
    "build": "npm run build:theme && npm run build:brand-assets && npm run build:ui && npm run build:cli",
    "build:theme": "npm run build -w @utlogiclabs/theme",
    "build:brand-assets": "npm run build -w @utlogiclabs/brand-assets",
    "build:ui": "npm run build -w @utlogiclabs/ui",
    "build:cli": "npm run build -w create-utlogiclabs-app",
    "dev:ui": "npm run storybook -w @utlogiclabs/ui",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "npm run clean --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsup": "^8.2.0",
    "prettier": "^3.3.0",
    "@types/node": "^20.14.0"
  },
  "engines": {
    "node": ">=20"
  }
}
