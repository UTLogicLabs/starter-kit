{
  "name": "@utlogiclabs/theme",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./tailwind-preset": {
      "types": "./dist/tailwind-preset.d.ts",
      "import": "./dist/tailwind-preset.js",
      "default": "./dist/tailwind-preset.js"
    },
    "./css": "./dist/css/tokens.css",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup && npm run copy:css",
    "copy:css": "mkdir -p dist/css && cp src/css/*.css dist/css/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "tailwindcss": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "devDependencies": {
    "tailwindcss": "^3.4.0",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0"
  }
}
